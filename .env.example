# ── Variables de entorno para Docker Compose ──────────────────────────────────
# Copia este archivo como .env y ajusta los valores antes de producción:
#   cp .env.example .env

# Contraseña del panel de administración (¡cámbiala!)
ADMIN_PASSWORD=admin123

# Secreto para firmar los tokens JWT (¡cámbialo por una cadena larga y aleatoria!)
JWT_SECRET=portafolio-secret-change-in-production

# URL que el navegador usa para llamar a la API.
# En desarrollo local con docker-compose: http://localhost:8080
# En producción: https://api.tudominio.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL del frontend que el backend incluye en los headers CORS.
# En producción: https://tudominio.com
FRONTEND_URL=http://localhost:3000
